# Ignore README, LICENSE, or other non-dotfile files

README.md
LICENSE

# Repo-only files: planning docs, doctor scaffolding, task runner.
# These live in the source repo but should never be written to $HOME.
OVERHAUL_PLAN.md
SWOT.md
scripts
justfile

# macOS metadata - Finder drops these into every visited directory.
# .gitignore already blocks tracking; this stops chezmoi from surfacing
# them via 'chezmoi add' or applying stray ones to $HOME.
.DS_Store
**/.DS_Store

# SSH: only ~/.ssh/config is tracked. Private keys, known_hosts, and the
# agent socket must never enter the source tree.
.ssh/id_*
.ssh/*.pub
.ssh/known_hosts
.ssh/known_hosts.old
.ssh/agent
.ssh/agent/**

# Neovim plugin state — managed by vim.pack, never tracked by chezmoi.
# Only ~/.config/nvim (init.lua, nvim-pack-lock.json) belongs in chezmoi.
.local/share/nvim
.local/share/nvim/**

# Oh My Zsh: installed via .chezmoiexternal.toml (pinned OMZ tarball
# plus separate tarballs for the p10k theme and the two zsh plugins).
# Ignore only:
#   - runtime state that OMZ regenerates on each shell startup
#   - upstream repo metadata (has no runtime value in $HOME)
# Everything the shell actually needs (lib/, plugins/, themes/, tools/,
# custom/themes/powerlevel10k, custom/plugins/zsh-*) is extracted from
# the pinned tarballs. Previously the whole 'custom/*' tree was ignored,
# which silently blocked the p10k+plugin externals from being applied.
.oh-my-zsh/cache
.oh-my-zsh/cache/**
.oh-my-zsh/log
.oh-my-zsh/log/**
.oh-my-zsh/.github
.oh-my-zsh/.github/**
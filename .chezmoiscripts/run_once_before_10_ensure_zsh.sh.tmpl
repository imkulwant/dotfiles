#!/bin/bash
set -euo pipefail
# Ensure Homebrew's zsh is installed and set as the default shell.
# Homebrew zsh (currently 5.9+) is newer than Apple's bundled /bin/zsh
# and is the version this repo's config targets.

HOMEBREW_ZSH="/opt/homebrew/bin/zsh"

if ! [ -x "$HOMEBREW_ZSH" ]; then
  echo "Installing Homebrew zsh..."
  brew install zsh
fi

# chsh requires the target shell to be listed in /etc/shells.
if ! grep -qxF "$HOMEBREW_ZSH" /etc/shells; then
  echo "Registering $HOMEBREW_ZSH in /etc/shells (needs sudo)..."
  echo "$HOMEBREW_ZSH" | sudo tee -a /etc/shells >/dev/null
fi

if [ "$SHELL" != "$HOMEBREW_ZSH" ]; then
  echo "Changing default shell to $HOMEBREW_ZSH..."
  chsh -s "$HOMEBREW_ZSH"
fi

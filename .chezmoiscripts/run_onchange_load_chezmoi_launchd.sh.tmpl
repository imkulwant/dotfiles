{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
set -euo pipefail
# Plist hash: {{ include "private_Library/LaunchAgents/com.kulsin.chezmoi-update.plist.tmpl" | sha256sum }}

PLIST="$HOME/Library/LaunchAgents/com.kulsin.chezmoi-update.plist"
LABEL="com.kulsin.chezmoi-update"
UID_="$(id -u)"

# Prefer the user domain: works over SSH, during initial setup before Aqua
# binds, and under MDM policies that restrict gui/<uid>. Fall back to the
# gui domain only if user/<uid> refuses (unusual, but seen on some hosts).
# Clear any stale bootstrap in either domain before re-loading.
launchctl bootout "user/$UID_/$LABEL" 2>/dev/null || true
launchctl bootout "gui/$UID_/$LABEL" 2>/dev/null || true

if launchctl bootstrap "user/$UID_" "$PLIST" 2>/dev/null; then
  echo "chezmoi-update launchd agent loaded (user/$UID_)."
elif launchctl bootstrap "gui/$UID_" "$PLIST" 2>/dev/null; then
  echo "chezmoi-update launchd agent loaded (gui/$UID_)."
else
  # Both domains rejected the bootstrap. Common on MDM-managed corporate
  # laptops that lock down launchctl. The agent is a nice-to-have (daily
  # `chezmoi update`) - skipping it must not fail the whole apply. Log the
  # underlying error for diagnostics and continue.
  echo "chezmoi-update launchd agent could not be loaded; skipping." >&2
  echo "  (run 'chezmoi update' manually to sync dotfiles)" >&2
  launchctl bootstrap "user/$UID_" "$PLIST" 2>&1 | sed 's/^/  /' >&2 || true
fi
{{ end -}}
